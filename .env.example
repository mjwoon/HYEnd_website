# ==========================================
# HY-END System Environment Variables Example
# ==========================================

# -----------------
# Backend Settings
# -----------------
# JWT Secret Key for Authentication
SECRET_KEY=tH+X6NUS6EhvGFGIjtYiTwPNi31+6NtEl9BYe8jqWwk=

# File Storage Configuration (local | s3)
FILE_STORAGE_TYPE=local

# -----------------
# AWS S3 Settings (Required if FILE_STORAGE_TYPE=s3)
# -----------------
AWS_S3_BUCKET=your_s3_bucket_name_here
AWS_S3_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# -----------------
# Frontend & Admin Settings
# -----------------
# API URL for Frontend & Admin to connect to Backend
VITE_API_URL=http://localhost:8080
